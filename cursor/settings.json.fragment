{
  "workbench.colorTheme": "Tokyo Night Storm",
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', 'SF Mono', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.cursorStyle": "block",
  "editor.cursorBlinking": "smooth",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontLigatures": true,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.minimumContrastRatio": 1,
  "workbench.colorCustomizations": {
    "terminal.background": "#1a1b26",
    "terminal.foreground": "#c0caf5",
    "terminalCursor.background": "#1a1b26",
    "terminalCursor.foreground": "#ff4fcf",
    "editorCursor.foreground": "#ff4fcf",
    "editorCursor.background": "#1a1b26",
    "editor.selectionBackground": "#ff4fcf44",
    "titleBar.activeBackground": "#1a1b26",
    "titleBar.activeForeground": "#c0caf5",
    "titleBar.inactiveBackground": "#1a1b26",
    "activityBar.background": "#1a1b26",
    "activityBar.foreground": "#c0caf5",
    "activityBar.activeBorder": "#ff4fcf",
    "activityBarBadge.background": "#ff4fcf",
    "activityBarBadge.foreground": "#1a1b26",
    "sideBar.background": "#1a1b26",
    "sideBar.foreground": "#c0caf5",
    "sideBarSectionHeader.background": "#16161e",
    "statusBar.background": "#16161e",
    "statusBar.foreground": "#c0caf5",
    "statusBarItem.remoteBackground": "#ff4fcf",
    "statusBarItem.remoteForeground": "#1a1b26",
    "panel.background": "#1a1b26",
    "panel.border": "#16161e",
    "tab.activeBorderTop": "#ff4fcf",
    "tab.activeBackground": "#1a1b26",
    "tab.inactiveBackground": "#16161e",
    "editorGroupHeader.tabsBackground": "#16161e"
  }
}
