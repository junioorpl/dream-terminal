# dream-terminal Ghostty config — Tokyo Night Storm + glass + shared keymap

# Font
font-family = JetBrainsMono Nerd Font
font-size = 14
font-feature = +calt
font-feature = +liga

# Theme — Tokyo Night Storm (built-in)
theme = tokyonight_storm
background-opacity = 0.78
background-blur-radius = 40
unfocused-split-opacity = 0.88
cursor-style = block
cursor-color = #ff4fcf
selection-background = #ff4fcf33

# Window / tabs
window-decoration = true
window-padding-x = 10
window-padding-y = 8
macos-titlebar-style = tabs
confirm-close-surface = false
quit-after-last-window-closed = false
gtk-single-instance = true

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Scrollback
scrollback-limit = 100000

# Quick terminal (drop-down)
quick-terminal-animation-duration = 0.1
quick-terminal-position = top

# --- Keybindings (shared keymap) ---

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+]=next_tab
keybind = cmd+shift+[=previous_tab
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9

# Splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+]=goto_split:next
keybind = cmd+[=goto_split:previous
keybind = cmd+shift+enter=toggle_split_zoom
keybind = cmd+alt+left=resize_split:left,10
keybind = cmd+alt+right=resize_split:right,10
keybind = cmd+alt+up=resize_split:up,10
keybind = cmd+alt+down=resize_split:down,10

# Utility
keybind = cmd+k=clear_screen
keybind = cmd+shift+comma=reload_config
keybind = cmd+grave_accent=toggle_quick_terminal
