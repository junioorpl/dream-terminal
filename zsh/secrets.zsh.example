# dream-terminal — secrets template
#
# Copy this file to a LOCAL non-tracked location (e.g., ~/.config/dream-terminal/secrets.zsh)
# and source it from ~/.zshrc AFTER the dream-terminal block if you want secret-env management
# outside of the (currently hardcoded) values in ~/.zshrc.
#
# DO NOT commit the real file. `.gitignore` already excludes zsh/secrets.zsh at repo root.

# export GITHUB_NPM_TOKEN="ghp_xxx"
# export OPENAI_API_KEY="sk-xxx"
# export ANTHROPIC_API_KEY="sk-ant-xxx"
